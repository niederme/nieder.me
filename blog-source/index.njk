---
layout: base.njk
pageType: index
title: "NiederBlog"
description: "Writing on product design, process, and craft by John Niedermeyer."
permalink: /blog/index.html
eleventyExcludeFromCollections: true
---
<section class="work-index-header" aria-labelledby="blog-title">
  <div class="rule"></div>
  <div class="work-index-header-copy">
    <h1 id="blog-title">NiederBlog</h1>
    <h2>Notes on design &amp; craft</h2>
  </div>
</section>

<section class="work-article-grid" aria-labelledby="blog-title">
  <article class="work-article-body">
    {% if collections.posts.length %}
    <ul class="blog-index-list">
      {%- for post in collections.posts %}
      <li class="blog-index-item">
        <a class="blog-index-link" href="{{ post.url | relUrl(page.url) }}">
          <p class="blog-post-meta">
            <time datetime="{{ post.data.date | dateISO }}">{{ post.data.date | dateDisplay }}</time>
          </p>
          <h3 class="blog-index-item-title">{{ post.data.title }}</h3>
          <p class="blog-index-item-desc">{{ post.data.description }}</p>
        </a>
      </li>
      {%- endfor %}
    </ul>
    {% else %}
    <section class="work-article-section">
      <p>No posts yet. Check back soon.</p>
    </section>
    {% endif %}
  </article>
</section>
