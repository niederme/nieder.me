          <img class="icon-on"    src="{{ root }}assets/icons/side-nav/icon-back-on.svg"    alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-back-hover.svg" alt="" />
          <span class="mobile-nav-label">Home</span>
        </a>
        <a class="mobile-nav-anchor" href="{{ root }}work/" aria-label="Work">
          <img class="icon-off"   src="{{ root }}assets/icons/side-nav/icon-work-experience-off.svg"   alt="" />
          <img class="icon-on"    src="{{ root }}assets/icons/side-nav/icon-work-experience-on.svg"    alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-work-experience-hover.svg" alt="" />
          <span class="mobile-nav-label">Work</span>
        </a>
        <a class="mobile-nav-anchor" href="{{ root }}about/" aria-label="About &amp; Biography">
          <img class="icon-off"   src="{{ root }}assets/icons/side-nav/icon-work-about-off.svg"   alt="" />
          <img class="icon-on"    src="{{ root }}assets/icons/side-nav/icon-work-about-on.svg"    alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-work-about-hover.svg" alt="" />
          <span class="mobile-nav-label">About</span>
        </a>
        <a class="mobile-nav-anchor" href="{{ root }}design-system/" aria-label="Design system">
          <img class="icon-off"   src="{{ root }}assets/icons/side-nav/icon-colophon-off.svg"   alt="" />
          <img class="icon-on"    src="{{ root }}assets/icons/side-nav/icon-colophon-on.svg"    alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-colophon-hover.svg" alt="" />
          <span class="mobile-nav-label">Design</span>
        </a>
        <a class="mobile-nav-anchor is-active" href="{{ root }}blog/" aria-label="Blog">
          <img class="icon-off"   src="{{ root }}assets/icons/side-nav/icon-blog-off.svg" alt="" />
          <img class="icon-on"    src="{{ root }}assets/icons/side-nav/icon-blog-on.svg"  alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-blog-on.svg"  alt="" />
          <span class="mobile-nav-label">Blog</span>
        </a>
        <div class="mobile-nav-toggles">
          <button class="theme-toggle is-off" type="button" aria-pressed="false" aria-label="Switch to light mode">
            <span class="theme-toggle-switch" aria-hidden="true"></span>
            <span class="theme-toggle-label">light</span>
            <span class="theme-toggle-state" aria-live="polite">Off</span>
          </button>
          <button class="cols-toggle is-off" type="button" aria-pressed="false" aria-label="Show column grid">
            <span class="cols-toggle-switch" aria-hidden="true"></span>
            <span class="cols-toggle-label">cols</span>
            <span class="cols-toggle-state" aria-live="polite">Off</span>
          </button>
        </div>
      </nav>

      <aside class="rail">
        <a class="logo-link" href="{{ root }}" aria-label="Back to homepage">
          <img class="logo-mark" src="{{ root }}assets/icons/logo-mark.svg" alt="JN monogram" />
        </a>
      </aside>

      <nav class="global-nav" aria-label="Primary navigation">
        <a class="global-nav-anchor" href="{{ root }}" aria-label="Back to homepage">
          <img class="icon-off" src="{{ root }}assets/icons/side-nav/icon-back-off.svg" alt="" />
          <img class="icon-on" src="{{ root }}assets/icons/side-nav/icon-back-on.svg" alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-back-hover.svg" alt="" />
          <span class="global-nav-popover" aria-hidden="true">Home</span>
        </a>
        <a class="global-nav-anchor" href="{{ root }}work/" aria-label="Work">
          <img class="icon-off" src="{{ root }}assets/icons/side-nav/icon-work-experience-off.svg" alt="" />
          <img class="icon-on" src="{{ root }}assets/icons/side-nav/icon-work-experience-on.svg" alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-work-experience-hover.svg" alt="" />
          <span class="global-nav-popover" aria-hidden="true">Work Experience &amp; Resume</span>
        </a>
        <a class="global-nav-anchor" href="{{ root }}about/" aria-label="About &amp; Biography">
          <img class="icon-off" src="{{ root }}assets/icons/side-nav/icon-work-about-off.svg" alt="" />
          <img class="icon-on" src="{{ root }}assets/icons/side-nav/icon-work-about-on.svg" alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-work-about-hover.svg" alt="" />
          <span class="global-nav-popover" aria-hidden="true">About &amp; Biography</span>
        </a>
        <a class="global-nav-anchor" href="{{ root }}design-system/" aria-label="Design system">
          <img class="icon-off" src="{{ root }}assets/icons/side-nav/icon-colophon-off.svg" alt="" />
          <img class="icon-on" src="{{ root }}assets/icons/side-nav/icon-colophon-on.svg" alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-colophon-hover.svg" alt="" />
          <span class="global-nav-popover" aria-hidden="true">Design System</span>
        </a>
        <a class="global-nav-anchor is-active" href="{{ root }}blog/" aria-label="Blog">
          <img class="icon-off" src="{{ root }}assets/icons/side-nav/icon-blog-off.svg" alt="" />
          <img class="icon-on" src="{{ root }}assets/icons/side-nav/icon-blog-on.svg" alt="" />
          <img class="icon-hover" src="{{ root }}assets/icons/side-nav/icon-blog-on.svg" alt="" />
          <span class="global-nav-popover" aria-hidden="true">Blog</span>
        </a>
        <div class="rail-controls-panel">
          <button class="theme-toggle is-off" type="button" aria-pressed="false" aria-label="Switch to light mode">
            <span class="theme-toggle-switch" aria-hidden="true"></span>
            <span class="theme-toggle-label">light</span>
            <span class="theme-toggle-state" aria-live="polite">Off</span>
          </button>
          <button class="cols-toggle is-off" type="button" aria-pressed="false" aria-label="Show column grid">
            <span class="cols-toggle-switch" aria-hidden="true"></span>
            <span class="cols-toggle-label">cols</span>
            <span class="cols-toggle-state" aria-live="polite">Off</span>
          </button>
        </div>
      </nav>

      <main class="work-article">
        <div class="work-grid-overlay" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <a class="mobile-logo-link" href="{{ root }}" aria-label="Back to homepage">
          <img class="mobile-logo-mark" src="{{ root }}assets/icons/logo-mark.svg" alt="JN monogram" />
        </a>

        {{ content | safe }}

        <footer class="site-footer" aria-label="Site footer">
          <div class="rule"></div>
          <div class="site-footer-grid">
            <div class="site-footer-brand">
              <p class="site-footer-name">John Niedermeyer</p>
              <p class="site-footer-role">Product Design &amp; Direction</p>
              <nav class="site-footer-connect" aria-label="Connect links">
                <ul class="site-footer-social">
                  <li>
                    <a href="https://github.com/niederme/" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile">
                      <span class="social-icon social-icon-github" aria-hidden="true"></span>
                    </a>
                  </li>
                  <li>
                    <a href="https://www.linkedin.com/in/niederme/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile">
                      <span class="social-icon social-icon-linkedin" aria-hidden="true"></span>
                    </a>
                  </li>
                  <li>
                    <a href="https://x.com/niederme/" target="_blank" rel="noopener noreferrer" aria-label="X profile">
                      <span class="social-icon social-icon-x" aria-hidden="true"></span>
                    </a>
                  </li>
                  <li>
                    <a href="https://instagram.com/niederme/" target="_blank" rel="noopener noreferrer" aria-label="Instagram profile">
                      <span class="social-icon social-icon-instagram" aria-hidden="true"></span>
