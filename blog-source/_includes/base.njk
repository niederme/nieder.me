{%- set root = page.url | relRoot -%}
{%- set imgPath = socialImage if socialImage else site.fallbackImage -%}
{%- set imgMeta = imgPath | imageMeta -%}
{%- set imgAbs = imgPath | absUrl -%}
{%- set imgAlt = socialImageAlt if socialImageAlt else site.fallbackImageAlt -%}
{%- set pageUrlAbs = page.url | absUrl -%}
{%- set ogType = "article" if pageType == "post" else "website" -%}
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#000000" />
    <meta name="color-scheme" content="dark" />
    <link rel="icon" href="{{ root }}favicon.ico?v={{ site.faviconVersion }}" sizes="any" />
    <link rel="icon" type="image/png" href="{{ root }}favicon.png?v={{ site.faviconVersion }}" />
    <link rel="apple-touch-icon" href="{{ root }}apple-touch-icon.png?v={{ site.faviconVersion }}" />
    <title>{{ title }} | {{ site.name }}</title>
    <meta name="description" content="{{ description }}" />
    <link rel="canonical" href="{{ pageUrlAbs }}" />

    <meta property="og:type" content="{{ ogType }}" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content="{{ title }} | {{ site.name }}" />
    <meta property="og:description" content="{{ description }}" />
    <meta property="og:url" content="{{ pageUrlAbs }}" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:image" content="{{ imgAbs }}" />
    <meta property="og:image:secure_url" content="{{ imgAbs }}" />
    <meta property="og:image:type" content="{{ imgMeta.type }}" />
    <meta property="og:image:width" content="{{ imgMeta.width }}" />
    <meta property="og:image:height" content="{{ imgMeta.height }}" />
    <meta property="og:image:alt" content="{{ imgAlt }}" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ title }} | {{ site.name }}" />
    <meta name="twitter:description" content="{{ description }}" />
    <meta name="twitter:url" content="{{ pageUrlAbs }}" />
    <meta name="twitter:image" content="{{ imgAbs }}" />
    <meta name="twitter:image:alt" content="{{ imgAlt }}" />
    <script>
      (() => {
        try {
          const storedTheme = window.localStorage.getItem("nieder.theme");
          const storedGrid = window.localStorage.getItem("nieder.cols-grid-visible");
          document.documentElement.dataset.grid = storedGrid === "1" ? "visible" : "hidden";
          if (storedTheme === "light") {
            document.documentElement.dataset.theme = "light";
            document.documentElement.style.colorScheme = "light";
            const themeColorMeta = document.querySelector('meta[name="theme-color"]');
            const colorSchemeMeta = document.querySelector('meta[name="color-scheme"]');
            if (themeColorMeta) themeColorMeta.setAttribute("content", "#ffffff");
            if (colorSchemeMeta) colorSchemeMeta.setAttribute("content", "light");
          }
        } catch (error) {
          document.documentElement.dataset.grid = "hidden";
          // Ignore storage access failures and keep the default state.
        }
      })();
    </script>
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <script>
      (() => {
        const hostname = window.location.hostname;
        const pathname = window.location.pathname;
        const isLocalPreview =
          hostname === "localhost" ||
          hostname === "127.0.0.1" ||
          hostname === "::1" ||
          hostname.endsWith(".local") ||
          /^(10\.|192\.168\.|172\.(1[6-9]|2\d|3[0-1])\.|100\.(6[4-9]|[7-9]\d|1[01]\d|12[0-7])\.)/.test(hostname);
        const isDraftPath = pathname.startsWith("/drafts/");

        if (isLocalPreview || isDraftPath) {
          window.niederAnalyticsSuppressed = true;
          return;
        }

        window.dataLayer = window.dataLayer || [];
        window.gtag = function gtag() {
          window.dataLayer.push(arguments);
        };

        const googleTag = document.createElement("script");
        googleTag.async = true;
        googleTag.src = "https://www.googletagmanager.com/gtag/js?id={{ site.ga4Id }}";
        document.head.appendChild(googleTag);

        window.gtag("js", new Date());
        window.gtag("config", "{{ site.ga4Id }}");
      })();
    </script>
    {% if pageType == "post" %}
      {{ { pageType: "post", slug: slug, url: pageUrlAbs, title: title, description: description, image: imgAbs, datePublished: date | dateISO, dateModified: (updated if updated else date) | dateISO } | jsonLd | safe }}
    {% else %}
      {{ { pageType: pageType, path: page.url, url: pageUrlAbs, title: title, description: description } | jsonLd | safe }}
    {% endif %}
    <link rel="stylesheet" href="{{ root }}assets/css/work-case-study.css?v={{ site.cssVersion }}" />
  </head>
  <body id="top" class="policy-page is-subpage">
    <div class="work-page">
      <nav class="mobile-nav" aria-label="Primary navigation">
        <a class="mobile-nav-anchor" href="{{ root }}" aria-label="Home">
