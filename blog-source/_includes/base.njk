                  </li>
                  <li>
                    <a data-email-link aria-label="Send email">
                      <span class="social-icon social-icon-email" aria-hidden="true"></span>
                    </a>
                  </li>
                </ul>
              </nav>
              <p class="site-footer-meta">© 2026 John Niedermeyer</p>
              <p class="site-footer-utility-links">
                <a href="{{ root }}accessibility/">Accessibility</a>
                <a href="{{ root }}privacy/">Privacy</a>
              </p>
            </div>

            <nav class="site-footer-column site-footer-column-site" aria-label="Site sections">
              <h3>Site</h3>
              <ul class="site-footer-links">
                <li><a href="{{ root }}">Home</a></li>
                <li><a href="{{ root }}work/">Work Experience &amp; Resume</a></li>
                <li><a href="{{ root }}about/">About &amp; Biography</a></li>
                <li><a href="{{ root }}design-system/">Design System</a></li>
                <li><a href="{{ root }}blog/" aria-current="page">Blog</a></li>
