---
layout: base.njk
---
{%- set root = page.url | relRoot -%}
{%- set displayTags = tags | displayTags -%}
<nav class="blog-top-nav blog-post-top-nav" aria-label="Blog navigation">
  <a href="{{ root }}blog/">
    <span class="blog-top-nav-line">
      <span class="blog-top-nav-brand">NiederBlog:</span>
      <span class="blog-top-nav-tagline">Notes on</span>
    </span>
    <span class="blog-top-nav-line blog-top-nav-tagline">Design &amp; Miscellany</span>
  </a>
</nav>

<section class="work-index-header blog-post-header" aria-labelledby="post-title">
  <div class="work-index-header-copy">
    <p class="blog-post-category">{{ category if category else "Notes" }}</p>
    <h1 id="post-title">{{ title }}</h1>
  </div>
</section>

<section class="work-article-grid blog-post-layout" aria-labelledby="post-title">
  <aside class="work-article-meta case-study-block case-study-block-meta blog-post-meta-panel" aria-label="Article metadata">
    <div class="case-study-block-inner">
      <div class="work-article-meta-card">
        <p class="work-article-meta-label">Published</p>
        <p class="work-article-meta-value">
          <time datetime="{{ date | dateISOFull }}">{{ date | dateTimeDisplay }}</time>
          {%- if updated %}<br />Updated <time datetime="{{ updated | dateISO }}">{{ updated | dateDisplay }}</time>{% endif -%}
        </p>
      </div>
      <div class="work-article-meta-card">
        <p class="work-article-meta-label">Byline</p>
        <p class="work-article-meta-value">John Niedermeyer</p>
      </div>
      {% if displayTags.length %}
      <div class="work-article-meta-card">
        <p class="work-article-meta-label">Tags</p>
        <ul class="blog-tag-list">
          {%- for tag in displayTags %}
          <li><a class="blog-tag" href="{{ root }}blog/tags/{{ tag | tagSlug }}/">#{{ tag }}</a></li>
          {%- endfor %}
        </ul>
      </div>
      {% endif %}
    </div>
  </aside>

  <article class="work-article-body blog-post-body">
    {{ content | safe }}
  </article>
</section>

{#- posts is date-descending, so the next item is older and the previous item is newer. -#}
{%- set olderPost = collections.posts | getNextCollectionItem -%}
{%- set newerPost = collections.posts | getPreviousCollectionItem -%}
{%- if olderPost or newerPost %}
<nav class="work-article-grid blog-post-pager" aria-label="More posts">
  <div class="rule blog-post-pager-rule"></div>
  {%- if olderPost %}
  <a class="blog-post-pager-link blog-post-pager-prev" href="{{ olderPost.url | relUrl(page.url) }}">
    <span class="blog-post-pager-label">← Previous</span>
    <span class="blog-post-pager-kicker">
      <span>{{ olderPost.data.category if olderPost.data.category else "Notes" }}</span>
      <span aria-hidden="true">|</span>
      <time datetime="{{ olderPost.data.date | dateISO }}">{{ olderPost.data.date | dateDisplay }}</time>
    </span>
    <span class="blog-post-pager-title">{{ olderPost.data.title }}</span>
  </a>
  {%- else %}<span class="blog-post-pager-prev" aria-hidden="true"></span>{% endif -%}
  {%- if newerPost %}
  <a class="blog-post-pager-link blog-post-pager-next" href="{{ newerPost.url | relUrl(page.url) }}">
    <span class="blog-post-pager-label">Next →</span>
    <span class="blog-post-pager-kicker">
      <span>{{ newerPost.data.category if newerPost.data.category else "Notes" }}</span>
      <span aria-hidden="true">|</span>
      <time datetime="{{ newerPost.data.date | dateISO }}">{{ newerPost.data.date | dateDisplay }}</time>
    </span>
    <span class="blog-post-pager-title">{{ newerPost.data.title }}</span>
  </a>
  {%- else %}<span class="blog-post-pager-next" aria-hidden="true"></span>{% endif -%}
</nav>
{% endif -%}
