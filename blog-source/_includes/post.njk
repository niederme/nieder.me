---
layout: base.njk
---
{%- set root = page.url | relRoot -%}
<section class="work-index-header" aria-labelledby="post-title">
  <div class="rule"></div>
  <div class="work-index-header-copy">
    <h1 id="post-title">{{ title }}</h1>
  </div>
</section>

<section class="work-article-grid" aria-labelledby="post-title">
  <article class="work-article-body blog-post-body">
    <section class="work-article-section">
      <p class="blog-post-meta">
        <time datetime="{{ date | dateISO }}">{{ date | dateDisplay }}</time>
        {%- if updated %} · Updated <time datetime="{{ updated | dateISO }}">{{ updated | dateDisplay }}</time>{% endif -%}
      </p>
    </section>

    {{ content | safe }}

    {%- set displayTags = [] -%}
    {%- for tag in tags -%}{% if tag != "posts" %}{% set displayTags = (displayTags.push(tag), displayTags) %}{% endif %}{%- endfor -%}
    {% if displayTags.length %}
    <section class="work-article-section blog-post-tags" aria-label="Tags">
      <ul class="blog-tag-list">
        {%- for tag in displayTags %}
        <li><a class="blog-tag" href="{{ root }}blog/tags/{{ tag | tagSlug }}/">#{{ tag }}</a></li>
        {%- endfor %}
      </ul>
    </section>
    {% endif %}

    <p class="about-recirc-wrap">
      <a class="work-index-card-cta" href="{{ root }}blog/">
        All writing
        <img src="{{ root }}assets/icons/arrow-case-study-red.svg" alt="" aria-hidden="true" />
      </a>
    </p>
  </article>
</section>
