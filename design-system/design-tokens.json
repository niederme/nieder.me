{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "nieder.me design tokens (W3C Design Tokens Community Group format). Extracted from assets/css/styles.css. Dark is the default theme; light values are noted in $extensions.theme.light.",
  "color": {
    "bg": {
      "$type": "color",
      "$value": "#000000",
      "$extensions": {
        "theme": {
          "light": "#ffffff"
        }
      }
    },
    "fg": {
      "$type": "color",
      "$value": "#ffffff",
      "$extensions": {
        "theme": {
          "light": "#121212"
        }
      }
    },
    "accent": {
      "$type": "color",
      "$value": "#ff453a"
    },
    "accentHover": {
      "$type": "color",
      "$value": "#ff6a60"
    },
    "line": {
      "$type": "color",
      "$value": "rgba(255,255,255,0.2)",
      "$extensions": {
        "theme": {
          "light": "#d6d0c6"
        }
      }
    },
    "muted": {
      "$type": "color",
      "$value": "#ebebf5",
      "$extensions": {
        "theme": {
          "light": "#474a51"
        }
      }
    },
    "footerMeta": {
      "$type": "color",
      "$value": "#8e8f98",
      "$extensions": {
        "theme": {
          "light": "#5f6268"
        }
      }
    },
    "surfaceAbout": {
      "$type": "color",
      "$value": "#111111",
      "$extensions": {
        "theme": {
          "light": "#f3eee5"
        }
      }
    },
    "surfaceColophon": {
      "$type": "color",
      "$value": "#121212",
      "$extensions": {
        "theme": {
          "light": "#f5efe5"
        }
      }
    },
    "focusRing": {
      "$type": "color",
      "$value": "rgba(255,69,58,0.75)"
    },
    "focusShadow": {
      "$type": "color",
      "$value": "rgba(255,69,58,0.25)"
    }
  },
  "fontFamily": {
    "sans": {
      "$type": "fontFamily",
      "$value": [
        "Sohne",
        "SF Pro Text",
        "SF Pro Display",
        "-apple-system",
        "BlinkMacSystemFont",
        "Helvetica Neue",
        "Arial Nova",
        "Arial",
        "sans-serif"
      ]
    }
  },
  "fontWeight": {
    "light": {
      "$type": "fontWeight",
      "$value": 300
    },
    "regular": {
      "$type": "fontWeight",
      "$value": 400
    },
    "bold": {
      "$type": "fontWeight",
      "$value": 700
    }
  },
  "fontSize": {
    "megaDisplay": {
      "$type": "dimension",
      "$value": "clamp(64px, 10vw, 196px)"
    },
    "heroDisplay": {
      "$type": "dimension",
      "$value": "clamp(52px, 7.7vw, 120px)"
    },
    "sectionDisplay": {
      "$type": "dimension",
      "$value": "clamp(112px, 7.9vw, 152px)"
    },
    "h2": {
      "$type": "dimension",
      "$value": "48px"
    },
    "h3": {
      "$type": "dimension",
      "$value": "42px"
    },
    "h4": {
      "$type": "dimension",
      "$value": "30px"
    },
    "h5": {
      "$type": "dimension",
      "$value": "26px"
    },
    "h6": {
      "$type": "dimension",
      "$value": "24px"
    },
    "bodyLead": {
      "$type": "dimension",
      "$value": "24px"
    },
    "body": {
      "$type": "dimension",
      "$value": "18px"
    },
    "bodySmall": {
      "$type": "dimension",
      "$value": "16px"
    },
    "meta": {
      "$type": "dimension",
      "$value": "13px"
    },
    "micro": {
      "$type": "dimension",
      "$value": "10px"
    }
  },
  "lineHeight": {
    "display": {
      "$type": "number",
      "$value": 0.9
    },
    "body": {
      "$type": "number",
      "$value": 1.35
    }
  },
  "letterSpacing": {
    "display": {
      "$type": "dimension",
      "$value": "-0.02em"
    }
  },
  "grid": {
    "columns": {
      "$type": "number",
      "$value": 12
    },
    "columnWidth": {
      "$type": "dimension",
      "$value": "69px"
    },
    "gutter": {
      "$type": "dimension",
      "$value": "40px"
    },
    "maxWidth": {
      "$type": "dimension",
      "$value": "1268px"
    }
  },
  "spacing": {
    "5": {
      "$type": "dimension",
      "$value": "5px"
    },
    "8": {
      "$type": "dimension",
      "$value": "8px"
    },
    "10": {
      "$type": "dimension",
      "$value": "10px"
    },
    "12": {
      "$type": "dimension",
      "$value": "12px"
    },
    "15": {
      "$type": "dimension",
      "$value": "15px"
    },
    "20": {
      "$type": "dimension",
      "$value": "20px"
    },
    "24": {
      "$type": "dimension",
      "$value": "24px"
    },
    "28": {
      "$type": "dimension",
      "$value": "28px"
    },
    "40": {
      "$type": "dimension",
      "$value": "40px"
    }
  },
  "radius": {
    "none": {
      "$type": "dimension",
      "$value": "0"
    },
    "sm": {
      "$type": "dimension",
      "$value": "5px"
    },
    "md": {
      "$type": "dimension",
      "$value": "10px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "16px"
    },
    "pill": {
      "$type": "dimension",
      "$value": "999px"
    },
    "circle": {
      "$type": "dimension",
      "$value": "50%"
    }
  }
}
